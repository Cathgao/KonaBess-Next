				label = "venus-ddr";
				qcom,bus-master = <0x3f>;
				qcom,bus-slave = <0x200>;
				qcom,mode = "venus-ddr";
				qcom,bus-range-kbps = <0x3e8 0x241648>;
			};

			arm9_bus_ddr {
				compatible = "qcom,msm-vidc,bus";
				label = "venus-arm9-ddr";
				qcom,bus-master = <0x3f>;
				qcom,bus-slave = <0x200>;
				qcom,mode = "performance";
				qcom,bus-range-kbps = <0x1 0x1>;
