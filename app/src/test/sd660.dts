	bt_wcn3990 {
		compatible = "qca,wcn3990";
		qca,bt-vdd-core-supply = <0x240>;
		qca,bt-vdd-pa-supply = <0x241>;
		qca,bt-vdd-ldo-supply = <0x242>;
		qca,bt-chip-pwd-supply = <0x243>;
