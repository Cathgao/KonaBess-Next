/dts-v1/;

/ {
	#address-cells = <0x2>;
	#size-cells = <0x2>;
	model = "Qualcomm Technologies, Inc. SDM 660 PM660 + PM660L MTP, Clover";
	compatible = "qcom,sdm660-mtp", "qcom,sdm660", "qcom,mtp";
	qcom,msm-id = <0x13d 0x0>;
	interrupt-parent = <0x1>;
	qcom,board-id = <0xb 0x0>;
	qcom,pmic-id = <0x1001b 0x101011a 0x0 0x0 0x1001b 0x201011a 0x0 0x0 0x1001b 0x102001a 0x0 0x0>;

	cpus {
		#address-cells = <0x2>;
		#size-cells = <0x0>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x0>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x400>;
			sched-energy-costs = <0x2>;
			qcom,lmh-dcvs = <0x3>;
			efficiency = <0x27c>;
			next-level-cache = <0x4>;
			#cooling-cells = <0x2>;
			phandle = <0x8>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x2>;
				qcom,dump-size = <0x0>;
				phandle = <0x4>;
			};

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@1 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x1>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x400>;
			sched-energy-costs = <0x2>;
			qcom,lmh-dcvs = <0x3>;
			#cooling-cells = <0x2>;
			efficiency = <0x27c>;
			next-level-cache = <0x4>;
			phandle = <0x9>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@2 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x2>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x400>;
			sched-energy-costs = <0x2>;
			qcom,lmh-dcvs = <0x3>;
			efficiency = <0x27c>;
			next-level-cache = <0x4>;
			#cooling-cells = <0x2>;
			phandle = <0xa>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@3 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x3>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x400>;
			sched-energy-costs = <0x2>;
			qcom,lmh-dcvs = <0x3>;
			efficiency = <0x27c>;
			next-level-cache = <0x4>;
			#cooling-cells = <0x2>;
			phandle = <0xb>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@100 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x100>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x666>;
			sched-energy-costs = <0x5>;
			qcom,lmh-dcvs = <0x6>;
			efficiency = <0x400>;
			next-level-cache = <0x7>;
			#cooling-cells = <0x2>;
			phandle = <0xc>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x2>;
				phandle = <0x7>;
			};

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@101 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x101>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x666>;
			sched-energy-costs = <0x5>;
			qcom,lmh-dcvs = <0x6>;
			#cooling-cells = <0x2>;
			efficiency = <0x400>;
			next-level-cache = <0x7>;
			phandle = <0xd>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@102 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x102>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x666>;
			sched-energy-costs = <0x5>;
			qcom,lmh-dcvs = <0x6>;
			#cooling-cells = <0x2>;
			efficiency = <0x400>;
			next-level-cache = <0x7>;
			phandle = <0xe>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu@103 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x0 0x103>;
			enable-method = "psci";
			capacity-dmips-mhz = <0x666>;
			sched-energy-costs = <0x5>;
			qcom,lmh-dcvs = <0x6>;
			#cooling-cells = <0x2>;
			efficiency = <0x400>;
			next-level-cache = <0x7>;
			phandle = <0xf>;

			l1-icache {
				compatible = "arm,arch-cache";
			};

			l1-dcache {
				compatible = "arm,arch-cache";
			};
		};

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x8>;
				};

				core1 {
					cpu = <0x9>;
				};

				core2 {
					cpu = <0xa>;
				};

				core3 {
					cpu = <0xb>;
				};
			};

			cluster1 {

				core0 {
					cpu = <0xc>;
				};

				core1 {
					cpu = <0xd>;
				};

				core2 {
					cpu = <0xe>;
				};

				core3 {
					cpu = <0xf>;
				};
			};
		};
	};

	soc {
		#address-cells = <0x1>;
		#size-cells = <0x1>;
		ranges = <0x0 0x0 0x0 0xffffffff>;
		compatible = "simple-bus";

		interrupt-controller@17a00000 {
			compatible = "arm,gic-v3";
			reg = <0x17a00000 0x10000 0x17b00000 0x100000>;
			#interrupt-cells = <0x3>;
			#address-cells = <0x1>;
			#size-cells = <0x1>;
			ranges;
			interrupt-controller;
			interrupt-parent = <0x10>;
			#redistributor-regions = <0x1>;
			redistributor-stride = <0x0 0x20000>;
			interrupts = <0x1 0x9 0x4>;
			phandle = <0x10>;
		};

		timer {
			compatible = "arm,armv8-timer";
			interrupts = <0x1 0x1 0xff08 0x1 0x2 0xff08 0x1 0x3 0xff08 0x1 0x0 0xff08>;
			clock-frequency = <0x124f800>;
		};

		qcom,sps-dma@0xc144000 {
			#dma-cells = <0x4>;
			compatible = "qcom,sps-dma";
			reg = <0xc144000 0x1f000>;
			interrupts = <0x0 0xee 0x4>;
			qcom,summing-threshold = <0x10>;
			phandle = <0x11e>;
		};

		qcom,sps-dma@0xc184000 {
			#dma-cells = <0x4>;
			compatible = "qcom,sps-dma";
			reg = <0xc184000 0x1f000>;
			interrupts = <0x0 0xef 0x4>;
			qcom,summing-threshold = <0x10>;
			phandle = <0x131>;
		};

		restart@10ac000 {
			compatible = "qcom,pshold";
			reg = <0x10ac000 0x4 0x1fd3000 0x4>;
			reg-names = "pshold-base", "tcsr-boot-misc-detect";
		};

		qcom,spmi@800f000 {
			compatible = "qcom,spmi-pmic-arb";
			reg = <0x800f000 0x1000 0x8400000 0x1000000 0x9400000 0x1000000 0xa400000 0x220000 0x800a000 0x3000>;
			reg-names = "core", "chnls", "obsrvr", "intr", "cnfg";
			interrupt-names = "periph_irq";
			interrupts = <0x0 0x146 0x4>;
			qcom,ee = <0x0>;
			qcom,channel = <0x0>;
			qcom,reserved-chan = <0x1ff>;
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;
			cell-index = <0x0>;
			status = "ok";
			phandle = <0x1c>;

			qcom,pm660@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x0 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					qcom,fab-id-valid;
					qcom,tp-rev-valid;
					phandle = <0x12>;
				};

				qcom,misc@900 {
					compatible = "qcom,qpnp-misc";
					reg = <0x900 0x100>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
					interrupts = <0x0 0x8 0x0 0x0 0x0 0x8 0x1 0x0 0x0 0x8 0x4 0x0 0x0 0x8 0x5 0x0>;
					interrupt-names = "kpdpwr", "resin", "resin-bark", "kpdpwr-resin-bark";
					qcom,pon-dbc-delay = <0x3d09>;
					qcom,kpdpwr-sw-debounce;
					qcom,system-reset;
					qcom,store-hard-reset-reason;

					qcom,pon_1 {
						qcom,pon-type = <0x0>;
						qcom,pull-up = <0x1>;
						linux,code = <0x74>;
						qcom,support-reset = <0x1>;
						qcom,s1-timer = <0x1a40>;
						qcom,s2-timer = <0x3e8>;
						qcom,s2-type = <0x7>;
					};

					qcom,pon_2 {
						qcom,pon-type = <0x1>;
						qcom,pull-up = <0x1>;
						linux,code = <0x72>;
					};

					qcom,pon_3 {
						qcom,pon-type = <0x3>;
						qcom,support-reset = <0x1>;
						qcom,pull-up = <0x1>;
						qcom,s1-timer = <0xc00>;
						qcom,s2-timer = <0x7d0>;
						qcom,s2-type = <0x1>;
						qcom,use-bark;
					};
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x0 0x24 0x0 0x1>;
					io-channels = <0x11 0x4f>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x1e>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xd00>;
					interrupts = <0x0 0xc0 0x0 0x0 0x0 0xc1 0x0 0x0 0x0 0xc2 0x0 0x0 0x0 0xc3 0x0 0x0 0x0 0xc4 0x0 0x0 0x0 0xc5 0x0 0x0 0x0 0xc6 0x0 0x0 0x0 0xc7 0x0 0x0 0x0 0xc8 0x0 0x0 0x0 0xc9 0x0 0x0 0x0 0xca 0x0 0x0 0x0 0xcb 0x0 0x0 0x0 0xcc 0x0 0x0>;
					interrupt-names = "pm660_gpio1", "pm660_gpio2", "pm660_gpio3", "pm660_gpio4", "pm660_gpio5", "pm660_gpio6", "pm660_gpio7", "pm660_gpio8", "pm660_gpio9", "pm660_gpio10", "pm660_gpio11", "pm660_gpio12", "pm660_gpio13";
					gpio-controller;
					#gpio-cells = <0x2>;
					phandle = <0x3d>;

					pmi_clk {

						pmi_clk_default {
							status = "ok";
							pins = "gpio3";
							function = "func1";
							output-enable;
							output-low;
							qcom,drive-strength = <0x2>;
							phandle = <0x203>;
						};
					};

					nfc_clk {

						nfc_clk_default {
							pins = "gpio4";
							function = "normal";
							input-enable;
							power-source = <0x1>;
							phandle = <0x13a>;
						};
					};

					home_key {

						home_key_default {
							pins = "gpio11";
							function = "normal";
							input-enable;
							bias-pull-up;
						};
					};

					gpio@c100 {
						status = "okay";
						qcom,master-en = <0x0>;
					};
				};

				qcom,pm660_rtc {
					compatible = "qcom,pm8941-rtc";
					interrupts = <0x0 0x61 0x1 0x0>;
				};

				qcom,pbs@7400 {
					compatible = "qcom,qpnp-pbs";
					reg = <0x7400 0x100>;
					status = "disabled";
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc-rev2";
					reg = <0x3100 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					interrupts = <0x0 0x31 0x0 0x1>;
					interrupt-names = "eoc-int-en-set";
					#io-channel-cells = <0x1>;
					io-channel-ranges;
					phandle = <0x11>;

					die_temp {
						reg = <0x6>;
						label = "die_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					ref_gnd {
						reg = <0x0>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vref_1p25 {
						reg = <0x1>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vph_pwr {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x1 0x3>;
					};

					vcoin {
						reg = <0x85>;
						label = "vcoin";
						qcom,pre-scaling = <0x1 0x3>;
					};

					xo_therm {
						reg = <0x4c>;
						label = "xo_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					msm_therm {
						reg = <0x4d>;
						label = "msm_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					quiet_therm {
						reg = <0x51>;
						label = "quiet_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					emmc_therm {
						reg = <0x4e>;
						label = "emmc_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					pa_therm0 {
						reg = <0x4f>;
						label = "pa_therm0";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					drax_temp {
						reg = <0x1d>;
						label = "drax_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					chan@12 {
						label = "gpio2_adc";
						reg = <0x12>;
						qcom,decimation = <0x2>;
						qcom,pre-div-channel-scaling = <0x0>;
						qcom,calibration-type = "absolute";
						qcom,scale-function = <0x0>;
						qcom,hw-settle-time = <0x2>;
						qcom,fast-avg-setup = <0x0>;
					};
				};

				qcom,qpnp-smb2 {
					compatible = "qcom,qpnp-smb2";
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					qcom,pmic-revid = <0x12>;
					io-channels = <0x13 0x8 0x13 0xa 0x13 0x3 0x13 0x4>;
					io-channel-names = "charger_temp", "charger_temp_max", "usbin_i", "usbin_v";
					qcom,wipower-max-uw = <0x4c4b40>;
					dpdm-supply = <0x14>;
					qcom,thermal-mitigation = <0x1e8480 0x1e8480 0x1e8480 0x16e360 0xf4240 0x7a120>;
					qcom,battery-data = <0x15>;
					qcom,usb-icl-ua = <0x1e8480>;
					qcom,dc-icl-ua = <0xf4240>;
					qcom,fcc-max-ua = <0x1e8480>;
					qcom,cool-fcc-ua = <0xf4240>;
					qcom,critical-low-fcc-ua = <0x4f588>;
					qcom,warm-fcc-ua = <0x19f0a0>;
					qcom,step-charging-enable;
					qcom,sw-jeita-enable;
					qcom,fv-max-uv = <0x432380>;
					qcom,auto-recharge-soc;

					qcom,chgr@1000 {
						reg = <0x1000 0x100>;
						interrupts = <0x0 0x10 0x0 0x1 0x0 0x10 0x1 0x1 0x0 0x10 0x2 0x1 0x0 0x10 0x3 0x1 0x0 0x10 0x4 0x1>;
						interrupt-names = "chg-error", "chg-state-change", "step-chg-state-change", "step-chg-soc-update-fail", "step-chg-soc-update-request";
					};

					qcom,otg@1100 {
						reg = <0x1100 0x100>;
						interrupts = <0x0 0x11 0x0 0x3 0x0 0x11 0x1 0x3 0x0 0x11 0x2 0x3 0x0 0x11 0x3 0x3>;
						interrupt-names = "otg-fail", "otg-overcurrent", "otg-oc-dis-sw-sts", "testmode-change-detect";
					};

					qcom,bat-if@1200 {
						reg = <0x1200 0x100>;
						interrupts = <0x0 0x12 0x0 0x1 0x0 0x12 0x1 0x3 0x0 0x12 0x2 0x3 0x0 0x12 0x3 0x3 0x0 0x12 0x4 0x3 0x0 0x12 0x5 0x3>;
						interrupt-names = "bat-temp", "bat-ocp", "bat-ov", "bat-low", "bat-therm-or-id-missing", "bat-terminal-missing";
					};

					qcom,usb-chgpth@1300 {
						reg = <0x1300 0x100>;
						interrupts = <0x0 0x13 0x0 0x3 0x0 0x13 0x1 0x3 0x0 0x13 0x2 0x3 0x0 0x13 0x3 0x3 0x0 0x13 0x4 0x3 0x0 0x13 0x5 0x1 0x0 0x13 0x6 0x1 0x0 0x13 0x7 0x1>;
						interrupt-names = "usbin-collapse", "usbin-lt-3p6v", "usbin-uv", "usbin-ov", "usbin-plugin", "usbin-src-change", "usbin-icl-change", "type-c-change";
					};

					qcom,dc-chgpth@1400 {
						reg = <0x1400 0x100>;
						interrupts = <0x0 0x14 0x0 0x3 0x0 0x14 0x1 0x3 0x0 0x14 0x2 0x3 0x0 0x14 0x3 0x3 0x0 0x14 0x4 0x3 0x0 0x14 0x5 0x3 0x0 0x14 0x6 0x1>;
						interrupt-names = "dcin-collapse", "dcin-lt-3p6v", "dcin-uv", "dcin-ov", "dcin-plugin", "div2-en-dg", "dcin-icl-change";
					};

					qcom,chgr-misc@1600 {
						reg = <0x1600 0x100>;
						interrupts = <0x0 0x16 0x0 0x1 0x0 0x16 0x1 0x1 0x0 0x16 0x2 0x3 0x0 0x16 0x3 0x3 0x0 0x16 0x4 0x3 0x0 0x16 0x5 0x3 0x0 0x16 0x6 0x2 0x0 0x16 0x7 0x3>;
						interrupt-names = "wdog-snarl", "wdog-bark", "aicl-fail", "aicl-done", "high-duty-cycle", "input-current-limiting", "temperature-change", "switcher-power-ok";
					};

					qcom,smb2-vbus {
						regulator-name = "smb2-vbus";
						phandle = <0x17>;
					};

					qcom,smb2-vconn {
						regulator-name = "smb2-vconn";
						phandle = <0x18>;
					};
				};

				qcom,usb-pdphy@1700 {
					compatible = "qcom,qpnp-pdphy";
					reg = <0x1700 0x100>;
					vdd-pdphy-supply = <0x16>;
					vbus-supply = <0x17>;
					vconn-supply = <0x18>;
					interrupts = <0x0 0x17 0x0 0x1 0x0 0x17 0x1 0x1 0x0 0x17 0x2 0x1 0x0 0x17 0x3 0x1 0x0 0x17 0x4 0x1 0x0 0x17 0x5 0x1 0x0 0x17 0x6 0x1>;
					interrupt-names = "sig-tx", "sig-rx", "msg-tx", "msg-rx", "msg-tx-failed", "msg-tx-discarded", "msg-rx-discarded";
					qcom,default-sink-caps = <0x1388 0xbb8 0x2328 0xbb8>;
					qcom,no-usb3-dp-concurrency;
					qcom,pd-20-source-only;
					phandle = <0x11a>;
				};

				vadc@3400 {
					compatible = "qcom,adc-tm-rev2";
					reg = <0x3400 0x100>;
					interrupts = <0x0 0x34 0x0 0x1>;
					interrupt-names = "thr-int-en";
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#thermal-sensor-cells = <0x1>;
					qcom,pmic-revid = <0x12>;
					io-channels = <0x11 0x4c 0x11 0x4d 0x11 0x51>;
					phandle = <0x20>;

					xo_therm {
						reg = <0x4c>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					msm_therm {
						reg = <0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					quiet_therm {
						reg = <0x51>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};
				};

				rradc@4500 {
					compatible = "qcom,rradc";
					reg = <0x4500 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#io-channel-cells = <0x1>;
					qcom,pmic-revid = <0x12>;
					phandle = <0x13>;
				};

				qpnp,fg {
					compatible = "qcom,fg-gen3";
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					qcom,pmic-revid = <0x12>;
					io-channels = <0x13 0x0 0x13 0x7>;
					io-channel-names = "rradc_batt_id", "rradc_die_temp";
					qcom,rradc-base = <0x4500>;
					qcom,fg-esr-timer-awake = <0x60 0x60>;
					qcom,fg-esr-timer-asleep = <0x100 0x100>;
					qcom,fg-esr-timer-charging = <0x0 0x60>;
					qcom,cycle-counter-en;
					status = "okay";
					qcom,battery-data = <0x15>;
					qcom,max-voltage-uv = <0x432380>;
					qcom,fg-cutoff-voltage = <0xd48>;
					qcom,fg-auto-recharge-soc;
					qcom,fg-recharge-soc-thr = <0x63>;
					qcom,hold-soc-while-full;
					qcom,fg-force-load-profile;
					qcom,fg-jeita-thresholds = <0xffffffe2 0xffffffec 0x46 0x4b>;
					qcom,battery-thermal-coefficients = [9d 50 ff];

					qcom,fg-batt-soc@4000 {
						status = "okay";
						reg = <0x4000 0x100>;
						interrupts = <0x0 0x40 0x0 0x3 0x0 0x40 0x1 0x3 0x0 0x40 0x2 0x1 0x0 0x40 0x3 0x1 0x0 0x40 0x4 0x3 0x0 0x40 0x5 0x1 0x0 0x40 0x6 0x3 0x0 0x40 0x7 0x3>;
						interrupt-names = "soc-update", "soc-ready", "bsoc-delta", "msoc-delta", "msoc-low", "msoc-empty", "msoc-high", "msoc-full";
					};

					qcom,fg-batt-info@4100 {
						status = "okay";
						reg = <0x4100 0x100>;
						interrupts = <0x0 0x41 0x0 0x3 0x0 0x41 0x1 0x3 0x0 0x41 0x2 0x3 0x0 0x41 0x3 0x3 0x0 0x41 0x6 0x3>;
						interrupt-names = "vbatt-pred-delta", "vbatt-low", "esr-delta", "batt-missing", "batt-temp-delta";
					};

					qcom,fg-memif@4400 {
						status = "okay";
						reg = <0x4400 0x100>;
						interrupts = <0x0 0x44 0x0 0x3 0x0 0x44 0x1 0x3 0x0 0x44 0x2 0x3>;
						interrupt-names = "ima-rdy", "mem-xcp", "dma-grant";
					};
				};

				bcl@4200 {
					compatible = "qcom,msm-bcl-lmh";
					reg = <0x4200 0xff 0x4300 0xff>;
					reg-names = "fg_user_adc", "fg_lmh";
					interrupts = <0x0 0x42 0x0 0x0 0x0 0x42 0x1 0x0 0x0 0x42 0x2 0x0 0x0 0x42 0x3 0x0 0x0 0x42 0x4 0x0>;
					interrupt-names = "bcl-high-ibat", "bcl-very-high-ibat", "bcl-low-vbat", "bcl-very-low-vbat", "bcl-crit-low-vbat";
					#thermal-sensor-cells = <0x1>;
					phandle = <0x21>;
				};
			};

			qcom,pm660@1 {
				compatible = "qcom,spmi-pmic";
				reg = <0x1 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,haptic@c000 {
					compatible = "qcom,pm660-haptics";
					reg = <0xc000 0x100>;
					interrupts = <0x1 0xc0 0x0 0x3 0x1 0xc0 0x1 0x3>;
					interrupt-names = "hap-sc-irq", "hap-play-irq";
					qcom,actuator-type = "lra";
					qcom,vmax-mv = <0xc80>;
					qcom,play-rate-us = <0x1a0b>;
					qcom,lra-resonance-sig-shape = "sine";
					qcom,lra-auto-resonance-mode = "qwd";
					qcom,lra-allow-variable-play-rate;
					status = "disabled";

					wf_0 {
						qcom,effect-id = <0x0>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = [3e 3e 3e];
						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,wf-brake-pattern = <0x1000000>;
						qcom,lra-auto-resonance-disable;
					};

					wf_1 {
						qcom,effect-id = <0x1>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = <0x7e7e0202 0x2020202>;
						qcom,wf-play-rate-us = <0x1be7>;
						qcom,wf-repeat-count = <0x2>;
						qcom,wf-s-repeat-count = <0x1>;
						qcom,lra-auto-resonance-disable;
					};

					wf_2 {
						qcom,effect-id = <0x2>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = [7e 7e];
						qcom,wf-play-rate-us = <0xfa0>;
						qcom,lra-auto-resonance-disable;
					};

					wf_3 {
						qcom,effect-id = <0x3>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = [7e 7e 7e];
						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,lra-auto-resonance-disable;
					};

					wf_4 {
						qcom,effect-id = <0x4>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = [7e 7e];
						qcom,wf-play-rate-us = <0x1388>;
						qcom,lra-auto-resonance-disable;
					};

					wf_5 {
						qcom,effect-id = <0x5>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = [7e 7e 7e];
						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,wf-brake-pattern = <0x3000000>;
						qcom,lra-auto-resonance-disable;
					};
				};
			};

			qcom,pm660l@2 {
				compatible = "qcom,spmi-pmic";
				reg = <0x2 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					phandle = <0x1a>;
				};

				qcom,pbs@7300 {
					compatible = "qcom,qpnp-pbs";
					reg = <0x7300 0x100>;
					phandle = <0x1b>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
					qcom,secondary-pon-reset;
					qcom,hard-reset-poweroff-type = <0x4>;
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x2 0x24 0x0 0x1>;
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x1f>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xc00>;
					interrupts = <0x2 0xc0 0x0 0x0 0x2 0xc1 0x0 0x0 0x2 0xc2 0x0 0x0 0x2 0xc3 0x0 0x0 0x2 0xc4 0x0 0x0 0x2 0xc5 0x0 0x0 0x2 0xc6 0x0 0x0 0x2 0xc7 0x0 0x0 0x2 0xc8 0x0 0x0 0x2 0xc9 0x0 0x0 0x2 0xca 0x0 0x0 0x2 0xcb 0x0 0x0>;
					interrupt-names = "pm660l_gpio1", "pm660l_gpio2", "pm660l_gpio3", "pm660l_gpio4", "pm660l_gpio5", "pm660l_gpio6", "pm660l_gpio7", "pm660l_gpio8", "pm660l_gpio9", "pm660l_gpio10", "pm660l_gpio11", "pm660l_gpio12";
					gpio-controller;
					#gpio-cells = <0x2>;
					phandle = <0x17d>;

					key_vol_up {

						key_vol_up_default {
							pins = "gpio7";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x0>;
							phandle = <0x20e>;
						};
					};

					cam_sensor_eldo3 {

						cam_sensor_eldo3_default {
							pins = "gpio3";
							function = "normal";
							output-high;
							bias-disable;
						};
					};

					cam_sensor_eldo4 {

						cam_sensor_eldo4_default {
							pins = "gpio4";
							function = "normal";
							output-low;
							bias-disable;
							phandle = <0x235>;
						};
					};

					gpio@c400 {
						status = "okay";
					};
				};
			};

			qcom,pm660l@3 {
				compatible = "qcom,spmi-pmic";
				reg = <0x3 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,pwms@b100 {
					compatible = "qcom,pwm-lpg";
					reg = <0xb100 0x300 0xb000 0x100>;
					reg-names = "lpg-base", "lut-base";
					#pwm-cells = <0x2>;
					qcom,num-lpg-channels = <0x3>;
					qcom,lut-patterns = <0x0 0xa 0x14 0x1e 0x28 0x32 0x3c 0x46 0x50 0x5a 0x64 0x5a 0x50 0x46 0x3c 0x32 0x28 0x1e 0x14 0xa 0x0>;
					phandle = <0x19>;

					lpg1 {
						qcom,lpg-chan-id = <0x1>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};

					lpg2 {
						qcom,lpg-chan-id = <0x2>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};

					lpg3 {
						qcom,lpg-chan-id = <0x3>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};
				};

				qcom,pwms@b400 {
					compatible = "qcom,pwm-lpg";
					reg = <0xb400 0x100>;
					reg-names = "lpg-base";
					#pwm-cells = <0x2>;
					qcom,num-lpg-channels = <0x1>;
				};

				qcom,leds@d000 {
					compatible = "qcom,tri-led";
					reg = <0xd000 0x100>;

					red {
						label = "red";
						pwms = <0x19 0x2 0xf4240>;
						led-sources = <0x0>;
						linux,default-trigger = "timer";
					};

					green {
						label = "green";
						pwms = <0x19 0x1 0xf4240>;
						led-sources = <0x1>;
						linux,default-trigger = "timer";
					};

					blue {
						label = "blue";
						pwms = <0x19 0x0 0xf4240>;
						led-sources = <0x2>;
						linux,default-trigger = "timer";
					};
				};

				qcom,leds@d800 {
					compatible = "qcom,qpnp-wled";
					reg = <0xd800 0x100 0xd900 0x100>;
					reg-names = "qpnp-wled-ctrl-base", "qpnp-wled-sink-base";
					interrupts = <0x3 0xd8 0x1 0x1>;
					interrupt-names = "ovp-irq";
					label = "backlight";
					qcom,pmic-revid = <0x1a>;
					qcom,auto-calibration;
					status = "ok";
					linux,name = "wled";
					linux,default-trigger = "bkl-trigger";
					qcom,fdbk-output = "auto";
					qcom,vref-uv = <0x1f20c>;
					qcom,switch-freq-khz = <0x320>;
					qcom,ovp-mv = <0x73a0>;
					qcom,ilim-ma = <0x3ca>;
					qcom,boost-duty-ns = <0x1a>;
					qcom,mod-freq-khz = <0x2580>;
					qcom,dim-mode = "hybrid";
					qcom,hyb-thres = <0x271>;
					qcom,sync-dly-us = <0x320>;
					qcom,fs-curr-ua = <0x61a8>;
					qcom,cons-sync-write-delay-us = <0x3e8>;
					qcom,led-strings-list = [00 01 02];
					qcom,en-cabc;
					qcom,loop-auto-gm-en;
					qcom,auto-calibration-enable;
				};

				qcom,leds@d300 {
					compatible = "qcom,qpnp-flash-led-v2";
					reg = <0xd300 0x100>;
					label = "flash";
					interrupts = <0x3 0xd3 0x0 0x1 0x3 0xd3 0x3 0x1 0x3 0xd3 0x4 0x1>;
					interrupt-names = "led-fault-irq", "all-ramp-down-done-irq", "all-ramp-up-done-irq";
					qcom,hdrm-auto-mode;
					qcom,short-circuit-det;
					qcom,open-circuit-det;
					qcom,vph-droop-det;
					qcom,thermal-derate-en;
					qcom,thermal-derate-current = <0xc8 0x1f4 0x3e8>;
					qcom,isc-delay = <0xc0>;
					qcom,pmic-revid = <0x1a>;

					qcom,flash_0 {
						label = "flash";
						qcom,led-name = "led:flash_0";
						qcom,max-current = <0x5dc>;
						qcom,default-led-trigger = "flash0_trigger";
						qcom,id = <0x0>;
						qcom,current-ma = <0x3e8>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x30d4>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x230>;
					};

					qcom,flash_1 {
						label = "flash";
						qcom,led-name = "led:flash_1";
						qcom,max-current = <0x5dc>;
						qcom,default-led-trigger = "flash1_trigger";
						qcom,id = <0x1>;
						qcom,current-ma = <0x3e8>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x30d4>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x231>;
					};

					qcom,flash_2 {
						label = "flash";
						qcom,led-name = "led:flash_2";
						qcom,max-current = <0x2ee>;
						qcom,default-led-trigger = "flash2_trigger";
						qcom,id = <0x2>;
						qcom,current-ma = <0x1f4>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x30d4>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
					};

					qcom,torch_0 {
						label = "torch";
						qcom,led-name = "led:torch_0";
						qcom,max-current = <0x1f4>;
						qcom,default-led-trigger = "torch0_trigger";
						qcom,id = <0x0>;
						qcom,current-ma = <0x12c>;
						qcom,ires-ua = <0x30d4>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x232>;
					};

					qcom,torch_1 {
						label = "torch";
						qcom,led-name = "led:torch_1";
						qcom,max-current = <0x1f4>;
						qcom,default-led-trigger = "torch1_trigger";
						qcom,id = <0x1>;
						qcom,current-ma = <0x12c>;
						qcom,ires-ua = <0x30d4>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
