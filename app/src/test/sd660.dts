		qcom,msm-audio-apr {
			compatible = "qcom,msm-audio-apr";
			qcom,subsys-name = "apr_adsp";

			qcom,msm-audio-ion {
				compatible = "qcom,msm-audio-ion";
				qcom,smmu-version = <0x2>;
				qcom,smmu-enabled;
				iommus = <0x88 0x1>;
				qcom,iommu-dma-addr-pool = <0x10000000 0x10000000>;
				qcom,smmu-sid-mask = <0x0 0xf>;
			};

			qcom,q6core-audio {
				compatible = "qcom,q6core-audio";

				lpi_pinctrl@15070000 {
					compatible = "qcom,lpi-pinctrl";
					reg = <0x15070000 0x0>;
					qcom,num-gpios = <0x20>;
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,lpi-offset-tbl = <0x0 0x1000 0x2000 0x2010 0x3000 0x3010 0x4000 0x4010 0x5000 0x5010 0x5020 0x5030 0x6000 0x6010 0x7000 0x7010 0x5040 0x5050 0x8000 0x8010 0x8020 0x8030 0x8040 0x8050 0x8060 0x8070 0x9000 0x9010 0xa000 0xa010 0xb000 0xb010>;

					lpi_mclk0_active {
						phandle = <0x205>;

						mux {
							pins = "gpio18";
							function = "func2";
						};

						config {
							pins = "gpio18";
							drive-strength = <0x8>;
							bias-disable;
						};
					};

					lpi_mclk0_sleep {
						phandle = <0x204>;

						mux {
							pins = "gpio18";
							function = "func2";
						};

						config {
							pins = "gpio18";
							drive-strength = <0x2>;
							bias-pull-down;
						};
					};

					cdc_pdm_gpios_active {
						phandle = <0x192>;

						mux {
							pins = "gpio18", "gpio19", "gpio21", "gpio23", "gpio25";
							function = "func1";
						};

						config {
							pins = "gpio18", "gpio19", "gpio21", "gpio23", "gpio25";
							drive-strength = <0x8>;
							output-high;
						};
					};

					cdc_pdm_gpios_sleep {
						phandle = <0x194>;

						mux {
							pins = "gpio18", "gpio19", "gpio21", "gpio23", "gpio25";
							function = "func1";
						};

						config {
							pins = "gpio18", "gpio19", "gpio21", "gpio23", "gpio25";
							drive-strength = <0x2>;
							bias-disable;
							output-low;
						};
					};

					cdc_pdm_2_gpios_active {
						phandle = <0x193>;

						mux {
							pins = "gpio20";
							function = "func1";
						};

						config {
							pins = "gpio20";
							drive-strength = <0x8>;
						};
					};

					cdc_pdm_2_gpios_sleep {
						phandle = <0x195>;

						mux {
							pins = "gpio20";
							function = "func1";
						};

						config {
							pins = "gpio20";
							drive-strength = <0x2>;
							bias-disable;
						};
					};

					cdc_pdm_comp_gpios_active {
						phandle = <0x196>;

						mux {
							pins = "gpio22", "gpio24";
							function = "func1";
						};

						config {
							pins = "gpio22", "gpio24";
							drive-strength = <0x8>;
						};
					};

					cdc_pdm_comp_gpios_sleep {
						phandle = <0x197>;

						mux {
							pins = "gpio22", "gpio24";
							function = "func1";
						};

						config {
							pins = "gpio22", "gpio24";
							drive-strength = <0x2>;
							bias-disable;
						};
					};

					lpi_cdc_reset_active {
						phandle = <0x19c>;

						mux {
							pins = "gpio24";
							function = "gpio";
						};

						config {
							pins = "gpio24";
							drive-strength = <0x10>;
							output-high;
						};
					};

					lpi_cdc_reset_sleep {
						phandle = <0x19d>;

						mux {
							pins = "gpio24";
							function = "gpio";
						};

						config {
							pins = "gpio24";
							drive-strength = <0x10>;
							bias-disable;
							output-low;
						};
					};

					dmic12_gpios_active {
						phandle = <0x198>;

						mux {
							pins = "gpio26", "gpio28";
							function = "func1";
						};

						config {
							pins = "gpio26", "gpio28";
							drive-strength = <0x8>;
							output-high;
						};
					};

					dmic12_gpios_sleep {
						phandle = <0x19a>;

						mux {
							pins = "gpio26", "gpio28";
							function = "func1";
						};

						config {
							pins = "gpio26", "gpio28";
							drive-strength = <0x2>;
							bias-disable;
							output-low;
						};
					};

					dmic34_gpios_active {
						phandle = <0x199>;

						mux {
							pins = "gpio27", "gpio29";
							function = "func1";
						};

						config {
							pins = "gpio27", "gpio29";
							drive-strength = <0x8>;
							input-enable;
						};
					};

					dmic34_gpios_sleep {
						phandle = <0x19b>;

						mux {
							pins = "gpio27", "gpio29";
							function = "func1";
						};

						config {
